# ocp-migration skill — runtime parameters
# Copy this file to .env in your project root and fill in all values.
# Lines starting with # are comments. Do not commit .env to version control.

# ── Identity ─────────────────────────────────────────────────────────────────
APP_NAME=                        # e.g. payments-api
DC=                              # data centre label, e.g. dc1 or east

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://<org>.atlassian.net
JIRA_PROJECT_KEY=                # e.g. PAY
JIRA_USER=                       # email or service account
JIRA_API_TOKEN=                  # PAT — never commit

# ── Bitbucket (Server API v1) ─────────────────────────────────────────────────
BITBUCKET_BASE_URL=https://bitbucket.<org>.com
BITBUCKET_PROJECT=               # project key, e.g. MYORG
BITBUCKET_USER=                  # service account username
BITBUCKET_TOKEN=                 # PAT — never commit

# Repo slugs — leave blank to let agent auto-derive from APP_NAME + DC
REPO_SLUG_APP=
REPO_SLUG_SECRETS=
REPO_SLUG_CERTS=
REPO_SLUG_XLR=

# ── Jenkins ──────────────────────────────────────────────────────────────────
JENKINS_BASE_URL=https://jenkins.<org>.com
JENKINS_JOB_PATH=                # e.g. MyFolder/payments-api
JENKINS_USER=
JENKINS_API_TOKEN=               # never commit

# ── XL Release ───────────────────────────────────────────────────────────────
XLR_BASE_URL=https://xlr.<org>.com
XLR_TEMPLATE_NAME=               # exact template title as it appears in XLR
XLR_FOLDER=                      # release folder path in XLR
XLR_USER=
XLR_API_TOKEN=                   # never commit

# ── OpenShift ────────────────────────────────────────────────────────────────
OCP_LOGIN_URL=https://api.<cluster>.<domain>:6443
OCP_LOGIN_TOKEN=                 # oc login token — never commit
                                 # get from: {OCP_LOGIN_URL}/oauth/token/request
OCP_NAMESPACE=                   # target project/namespace
OCP_IMAGE_REGISTRY=image-registry.openshift-image-registry.svc:5000

# ── TLS (used for local keytool inspection and OCP secret creation) ───────────
KEYSTORE_PASSWORD=               # never commit — obtain from vault/secrets manager
TRUSTSTORE_PASSWORD=             # never commit

# ── Local run ────────────────────────────────────────────────────────────────
LOCAL_APP_PORT=8080
REFERENCE_PROJECT_PATH=          # absolute path to reference migration project

# ── Runtime control ───────────────────────────────────────────────────────────
MAX_RETRY=3

# ── Phase command contract (must be non-interactive and idempotent) ─────────
# Each phase script executes the corresponding command string below.
# Keep secrets in env vars, not inline in these command values.
PHASE_0_CMD=
PHASE_1_CMD=
PHASE_2_CMD=
PHASE_3_CMD=
PHASE_4_CMD=
PHASE_5_CMD=
PHASE_6_CMD=
PHASE_7_CMD=
PHASE_8_CMD=
PHASE_9_CMD=
PHASE_10_CMD=
